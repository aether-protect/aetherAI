# Earendel Agent CDK Configuration
# Copy this file to .env and follow the two-phase deployment process

# =================================================================
# PHASE 1: Deploy Base Infrastructure
# =================================================================
# Leave MODEL_S3_URI and INFERENCE_IMAGE_URI empty, then run:
#   cdk deploy EarendelAgentStack
#
# After deployment, note the outputs:
#   - ModelBucketName: S3 bucket created for model artifacts
#   - InferenceRepoUri: ECR repository URI

AWS_REGION=us-east-1
SAGEMAKER_ENDPOINT_NAME=earendel-threat-detector
SAGEMAKER_INSTANCE_TYPE=ml.t2.medium
MODEL_BUCKET_NAME=

# =================================================================
# PHASE 2: Upload model and build container
# =================================================================
# 1. Download model from GitHub release:
#    curl -L -o model.tar.gz https://github.com/jinnius1/earendel/releases/download/v1.0.0/model.tar.gz
#
# 2. Upload model to S3 (replace {ModelBucketName} with Phase 1 output):
#    aws s3 cp model.tar.gz s3://{ModelBucketName}/model/model.tar.gz
#
# 3. Build container:
#    aws codebuild start-build --project-name earendel-onnx-build --region us-east-1
#
# 4. Fill in values from Phase 1 outputs and redeploy:
MODEL_S3_URI=
INFERENCE_IMAGE_URI=

# Example:
# MODEL_S3_URI=s3://earendelagentstack-modelbucket-xxx/model/model.tar.gz
# INFERENCE_IMAGE_URI=123456789.dkr.ecr.us-east-1.amazonaws.com/earendel-onnx-inference:latest
